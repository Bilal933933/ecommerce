# ═══════════════════════════════════════════════════════════════════════════════
# منصة البيان التعليمية - متغيرات البيئة
# ═══════════════════════════════════════════════════════════════════════════════
# 
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# cp .env.example .env
#

# ────────────────────────────────────────────────────────────────────────────────
# ⚙️  إعدادات الخادم
# ────────────────────────────────────────────────────────────────────────────────

# منفذ الخادم
PORT=3000

# بيئة التطوير (development, production, test)
NODE_ENV=development

# ────────────────────────────────────────────────────────────────────────────────
# 🌐 CORS - السماح بطلبات من نطاقات معينة
# ────────────────────────────────────────────────────────────────────────────────

# أصل موقع الويب (Frontend)
CORS_ORIGIN_WEB=http://localhost:5173

# أصل موقع لوحة التحكم (Admin Panel)
CORS_ORIGIN_ADMIN=http://localhost:5174

# ────────────────────────────────────────────────────────────────────────────────
# 🗄️  قاعدة البيانات PostgreSQL
# ────────────────────────────────────────────────────────────────────────────────

# اتصال قاعدة البيانات (PostgreSQL)
# الصيغة: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# المثال:
DATABASE_URL=postgresql://postgres:password@localhost:5432/bayyan_db

# ────────────────────────────────────────────────────────────────────────────────
# 🔐 JWT - المصادقة والتوكنات
# ────────────────────────────────────────────────────────────────────────────────

# مفتاح سري لتوقيع JWT (يجب أن يكون قوياً وفريداً)
# يمكنك توليد مفتاح عشوائي: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_here_min_32_characters_long_secure_key

# مدة صلاحية الـ Access Token (مثال: 7d, 24h, 1h)
JWT_EXPIRATION=7d

# مفتاح سري لـ Refresh Token
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_characters_long_secure_key

# مدة صلاحية الـ Refresh Token
JWT_REFRESH_EXPIRATION=30d

# ────────────────────────────────────────────────────────────────────────────────
# 📧 خدمة البريد الإلكتروني (Resend)
# ────────────────────────────────────────────────────────────────────────────────

# مفتاح API من Resend (احصل عليه من https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# البريد الإلكتروني المرسل (يجب أن يكون مصرح من Resend)
SENDER_EMAIL=noreply@bayyan.edu

# ────────────────────────────────────────────────────────────────────────────────
# 📱 معلومات التطبيق
# ────────────────────────────────────────────────────────────────────────────────

# اسم التطبيق
APP_NAME="منصة البيان التعليمية"

# رابط التطبيق الأساسي
APP_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────────────────────
# 📊 Logging
# ────────────────────────────────────────────────────────────────────────────────

# مستوى التسجيل (debug, info, warn, error)
LOG_LEVEL=debug

# ────────────────────────────────────────────────────────────────────────────────
# نصائح للأمان:
# ────────────────────────────────────────────────────────────────────────────────
# ⚠️  لا تشارك ملف .env عبر Version Control
# ⚠️  أضف .env إلى .gitignore
# ⚠️  استخدم مفاتيح قوية وفريدة في الإنتاج
# ⚠️  غيّر جميع القيم الافتراضية قبل النشر
# ⚠️  استخدم متغيرات بيئة آمنة في الإنتاج (AWS Secrets, Azure Key Vault, etc.)
